{
  "name": "new-workbench-agent-vscode",
  "displayName": "New Workbench Agent - AI Agent complete your work in second for Code Editors",
  "description": "Completely your workflow for task/bug in a second",
  "version": "0.1.0",
  "publisher": "b0yblake",
  "engines": {
    "vscode": "^1.107.0"
  },
  "extensionKind": [
    "ui"
  ],
  "icon": "nwa-agent.png",
  "categories": [
    "Other",
    "Snippets",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "agents",
    "claude",
    "cursor",
    "copilot",
    "claude-code",
    "ai-agents",
    "productivity",
    "automation",
    "sub-agents",
    "ai-tools"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:nwaAgent.startFigmaMcpBridge",
    "onCommand:nwaAgent.stopFigmaMcpBridge",
    "onCommand:nwaAgent.showFigmaMcpStatus"
  ],
  "main": "dist/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "nwaAgent.figmaMcpProvider",
        "label": "NWA Agent Figma MCP Provider"
      }
    ],
    "commands": [
      {
        "command": "nwa.openPanel",
        "title": "NWA: Open Agent Manager",
        "icon": "$(robot)"
      },
      {
        "command": "nwa.quickInit",
        "title": "NWA: Quick Setup",
        "icon": "$(zap)"
      },
      {
        "command": "nwa.initAgents",
        "title": "NWA: Initialize Agents"
      },
      {
        "command": "nwa.initClaudeResource",
        "title": "NWA: Skills selection",
        "icon": "$(add)"
      },
      {
        "command": "nwa.initClaudeEnvironment",
        "title": "Install Helpers",
        "icon": "$(terminal)"
      },
      {
        "command": "nwa.openTaskManager",
        "title": "NWA: Task",
        "icon": "$(checklist)"
      },
      {
        "command": "nwa.openWorkflowSettings",
        "title": "NWA: Workflow Settings",
        "icon": "$(gear)"
      },
      {
        "command": "nwa.openWorkflows",
        "title": "NWA: Workflows",
        "icon": "$(circuit-board)"
      },
      {
        "command": "nwa.viewAgent",
        "title": "NWA: View Agent Details"
      },
      {
        "command": "nwa.openSettings",
        "title": "NWA: Open Settings"
      },
      {
        "command": "nwa.previewAgent",
        "title": "NWA: Preview Agent"
      },
      {
        "command": "nwa.memory.addManualMemory",
        "title": "NWA: Add Memory",
        "icon": "$(add)"
      },
      {
        "command": "nwa.memory.searchMemory",
        "title": "NWA: Search Memory",
        "icon": "$(search)"
      },
      {
        "command": "nwa.memory.showMemory",
        "title": "NWA: Show All Memories",
        "icon": "$(list-unordered)"
      },
      {
        "command": "nwa.memory.clearMemory",
        "title": "NWA: Clear All Memories",
        "icon": "$(trash)"
      },
      {
        "command": "nwa.memory.refreshTree",
        "title": "NWA: Refresh Memory",
        "icon": "$(refresh)"
      },
      {
        "command": "nwaAgent.startFigmaMcpBridge",
        "title": "NWA Agent: Start Figma MCP Bridge"
      },
      {
        "command": "nwaAgent.stopFigmaMcpBridge",
        "title": "NWA Agent: Stop Figma MCP Bridge"
      },
      {
        "command": "nwaAgent.showFigmaMcpStatus",
        "title": "NWA Agent: Show Figma MCP Status"
      },
      {
        "command": "nwa.components.refresh",
        "title": "NWA: Refresh Component Browser",
        "icon": "$(refresh)"
      },
      {
        "command": "nwa.components.addPath",
        "title": "NWA: Add Component Scan Path",
        "icon": "$(add)"
      },
      {
        "command": "nwa.components.removePath",
        "title": "NWA: Remove Component Scan Path",
        "icon": "$(trash)"
      },
      {
        "command": "nwa.components.openFile",
        "title": "Open Component File"
      },
      {
        "command": "nwa.components.copyPath",
        "title": "Copy Component File Path"
      },
      {
        "command": "nwa.components.copyImport",
        "title": "Copy Import Statement"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nwa-sidebar",
          "title": "NWA",
          "icon": "media/octopus.svg"
        }
      ]
    },
    "views": {
      "nwa-sidebar": [
        {
          "id": "nwa-claude-initial-context",
          "name": "Tools",
          "icon": "$(cloud-download)",
          "contextualTitle": "Tools"
        },
        {
          "id": "nwa-task",
          "name": "Task",
          "icon": "$(checklist)",
          "contextualTitle": "NWA Task"
        },
        {
          "id": "nwa-memory",
          "name": "Memory",
          "icon": "$(bookmark)",
          "contextualTitle": "NWA Memory"
        },
        {
          "id": "nwa-component-browser",
          "name": "Component Browser",
          "icon": "$(symbol-class)",
          "contextualTitle": "NWA Components"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "nwa-claude-initial-context",
        "contents": "Set up Claude context resources.\n[Install Helpers](command:nwa.initClaudeEnvironment)\n[Skills selection](command:nwa.initClaudeResource)"
      },
      {
        "view": "nwa-task",
        "contents": "Prepare task context.\n[Task](command:nwa.openTaskManager)\n[Settings](command:nwa.openWorkflowSettings)\n[Workflows](command:nwa.openWorkflows)"
      },
      {
        "view": "nwa-memory",
        "contents": "No memories yet.\n[Add Memory](command:nwa.memory.addManualMemory)\n[Search Memory](command:nwa.memory.searchMemory)"
      },
      {
        "view": "nwa-component-browser",
        "contents": "No components scanned yet.\nThe Component Browser detects atomic / molecular / organism components in your Vue, React, Angular, or Svelte source.\n[Add Scan Path](command:nwa.components.addPath)\n[Refresh](command:nwa.components.refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "nwa.initClaudeEnvironment",
          "when": "view == nwa-claude-initial-context",
          "group": "navigation@0"
        },
        {
          "command": "nwa.initClaudeResource",
          "when": "view == nwa-claude-initial-context",
          "group": "1_actions@1"
        },
        {
          "command": "nwa.memory.addManualMemory",
          "when": "view == nwa-memory",
          "group": "navigation@1"
        },
        {
          "command": "nwa.memory.searchMemory",
          "when": "view == nwa-memory",
          "group": "navigation@2"
        },
        {
          "command": "nwa.memory.refreshTree",
          "when": "view == nwa-memory",
          "group": "navigation@3"
        },
        {
          "command": "nwa.memory.clearMemory",
          "when": "view == nwa-memory",
          "group": "1_manage@1"
        },
        {
          "command": "nwa.components.refresh",
          "when": "view == nwa-component-browser",
          "group": "navigation@1"
        },
        {
          "command": "nwa.components.addPath",
          "when": "view == nwa-component-browser",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "nwa.openPanel"
        },
        {
          "command": "nwa.quickInit"
        },
        {
          "command": "nwa.initAgents"
        },
        {
          "command": "nwa.initClaudeResource"
        },
        {
          "command": "nwa.initClaudeEnvironment"
        },
        {
          "command": "nwa.openTaskManager"
        },
        {
          "command": "nwa.openWorkflowSettings"
        },
        {
          "command": "nwa.openWorkflows"
        },
        {
          "command": "nwa.viewAgent"
        },
        {
          "command": "nwa.previewAgent",
          "when": "false"
        },
        {
          "command": "nwa.memory.addManualMemory"
        },
        {
          "command": "nwa.memory.searchMemory"
        },
        {
          "command": "nwa.memory.showMemory"
        },
        {
          "command": "nwa.memory.clearMemory"
        },
        {
          "command": "nwa.memory.refreshTree",
          "when": "false"
        },
        {
          "command": "nwaAgent.startFigmaMcpBridge"
        },
        {
          "command": "nwaAgent.stopFigmaMcpBridge"
        },
        {
          "command": "nwaAgent.showFigmaMcpStatus"
        },
        {
          "command": "nwa.components.refresh"
        },
        {
          "command": "nwa.components.addPath"
        },
        {
          "command": "nwa.components.removePath"
        },
        {
          "command": "nwa.components.openFile",
          "when": "false"
        },
        {
          "command": "nwa.components.copyPath",
          "when": "false"
        },
        {
          "command": "nwa.components.copyImport",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "nwa.components.openFile",
          "when": "view == nwa-component-browser && viewItem == component",
          "group": "1_open@1"
        },
        {
          "command": "nwa.components.copyPath",
          "when": "view == nwa-component-browser && viewItem == component",
          "group": "2_copy@1"
        },
        {
          "command": "nwa.components.copyImport",
          "when": "view == nwa-component-browser && viewItem == component",
          "group": "2_copy@2"
        },
        {
          "command": "nwa.components.addPath",
          "when": "view == nwa-component-browser && viewItem == componentPaths",
          "group": "1_paths@1"
        },
        {
          "command": "nwa.components.removePath",
          "when": "view == nwa-component-browser && viewItem == componentPath",
          "group": "1_paths@1"
        }
      ]
    },
    "configuration": {
      "title": "NWA",
      "properties": {
        "nwa.defaultTool": {
          "type": "string",
          "enum": [
            "cursor",
            "claude-code",
            "copilot",
            "aider",
            "universal"
          ],
          "enumDescriptions": [
            "Cursor - @-mentions and multi-file support",
            "Claude Code - Native sub-agent support",
            "GitHub Copilot - copilot-instructions.md",
            "Aider - conventions.md",
            "Universal - Works with any tool"
          ],
          "default": "cursor",
          "description": "Default AI tool for agent configuration"
        },
        "nwa.defaultFolder": {
          "type": "string",
          "default": "",
          "description": "Custom default folder name (leave empty for tool-specific defaults)"
        },
        "nwa.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh agent list when files change"
        },
        "nwa.showWelcome": {
          "type": "boolean",
          "default": true,
          "description": "Show welcome message on first use"
        },
        "nwa.defaultDepartments": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "design",
              "engineering",
              "marketing",
              "product",
              "project-management",
              "studio-operations",
              "testing"
            ]
          },
          "default": [
            "engineering",
            "design"
          ],
          "description": "Default departments to select"
        },
        "nwa.favoriteAgents": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of favorite agent IDs"
        },
        "nwa.taskDocumentsFolder": {
          "type": "string",
          "default": ".project/docs",
          "description": "Workspace-relative folder where Task Manager stores markdown documents converted with markitdown"
        },
        "nwa.componentPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "src/components",
            "src/atoms",
            "src/molecules",
            "src/organisms",
            "src/shared/components",
            "src/ui"
          ],
          "markdownDescription": "**Component scan paths** (workspace-relative). The Component Browser and Figma plugin catalog scan Vue, React, Angular, and Svelte components in these folders.",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "compile": "tsc -p ./",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "test": "jest",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies",
    "publish": "npm run build && npx @vscode/vsce publish --no-dependencies",
    "publish:ovsx": "npm run build && npx ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.107.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.x",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-icons": "^13.0.0",
    "@nwa/task-kernel": "*",
    "@nwa/step-auto-commit": "*",
    "@nwa/step-automation-test": "*",
    "@nwa/step-code": "*",
    "@nwa/step-collect-document": "*",
    "@nwa/step-collect-figma": "*",
    "@nwa/step-collect-jira": "*",
    "@nwa/step-review-ai": "*",
    "@nwa/step-review-human": "*",
    "@nwa/step-testcase": "*",
    "@nwa/step-unit-test": "*",
    "@nwa/spec-generator": "*",
    "@nwa/workflow-sdk": "*",
    "minimatch": "^9.0.3",
    "playwright": "^1.59.1",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "author": "b0yblake",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/b0yblake/New-Workbench-Agent"
  },
  "bugs": {
    "url": "https://github.com/b0yblake/New-Workbench-Agent/issues"
  },
  "homepage": "https://github.com/b0yblake/New-Workbench-Agent#readme"
}
